# 复制为 .env 后修改强密码：
# cp .env.example .env

# ========= App =========
SERVER_PORT=8081
APP_LOG_LEVEL=info
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl
JAVA_OPTS=-Xms256m -Xmx512m
TZ=Asia/Shanghai

# 上传文件在容器内的位置；docker-compose 会把宿主机 ./uploads 挂载到这里
APP_UPLOAD_PATH=/app/uploads
UPLOAD_MAX_FILE_SIZE=50MB
UPLOAD_MAX_REQUEST_SIZE=50MB

# ========= MySQL =========
# 本地 IDEA 直跑可把 MYSQL_HOST 改成你的 MySQL IP；Docker Compose 会自动覆盖为 mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=to_my_l
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ========= Redis =========
# 本地 IDEA 直跑可把 REDIS_HOST 改成你的 Redis IP；Docker Compose 会自动覆盖为 redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DATABASE=0

# ========= Flyway =========
# 接管数据库迁移：默认 false 不会动 schema。
#   首次开启时建议先备份再切 true，并把 FLYWAY_BASELINE_VERSION 设到当前数据库
#   已有的最高 V 版本（你云上手工跑过的 ALTER 之后），避免 Flyway 重复跑。
#   全新空库可把 FLYWAY_BASELINE_VERSION 设为 0，让 Flyway 从 V1 起依序建表。
FLYWAY_ENABLED=false
FLYWAY_BASELINE_VERSION=1
FLYWAY_BASELINE_ON_MIGRATE=true

# ========= SaToken =========
# 绝对过期（秒）：从 token 创建开始倒数，到点强制重登。
SA_TOKEN_TIMEOUT=2592000          # 30d
# 活跃过期（秒）：每次接口访问会被重置；连续不动这么久视为过期。
SA_TOKEN_ACTIVE_TIMEOUT=604800    # 7d
# 滑动续期。开启后只要还活跃就自动续命。
SA_TOKEN_AUTO_RENEW=true
